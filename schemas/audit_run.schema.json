{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/offlyn-ai/offlyn-token-savings-audit/schemas/audit_run.schema.json",
  "title": "Audit Run",
  "description": "Schema for a complete audit execution result including all architectures and metrics.",
  "type": "object",
  "required": ["run_id", "timestamp", "assumptions_version", "architectures", "claim_level"],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this audit run"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the audit was generated"
    },
    "assumptions_version": {
      "type": "string",
      "description": "Git commit hash or version of assumptions used"
    },
    "claim_level": {
      "type": "string",
      "enum": ["modeled_not_verified", "measured_not_verified", "third_party_verified"]
    },
    "reporting_mode": {
      "type": "string",
      "enum": ["operational_proxy", "operational_plus_embodied_estimate", "third_party_verified"]
    },
    "sci_ai_boundary": {
      "type": "string",
      "enum": ["consumer", "provider", "both"]
    },
    "architectures": {
      "type": "object",
      "required": ["cloud_first", "offline_first", "hybrid_router"],
      "properties": {
        "cloud_first": { "$ref": "#/$defs/architecture_result" },
        "offline_first": { "$ref": "#/$defs/architecture_result" },
        "hybrid_router": { "$ref": "#/$defs/architecture_result" }
      }
    },
    "functional_units": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "cloud_first": { "type": "number" },
          "offline_first": { "type": "number" },
          "hybrid_router": { "type": "number" }
        }
      }
    }
  },
  "$defs": {
    "architecture_result": {
      "type": "object",
      "required": ["cloud_billable_tokens", "total_consumer_carbon_gco2e"],
      "properties": {
        "cloud_billable_tokens": { "type": "integer", "minimum": 0 },
        "cloud_llm_input_tokens": { "type": "integer", "minimum": 0 },
        "cloud_llm_output_tokens": { "type": "integer", "minimum": 0 },
        "cloud_embedding_tokens": { "type": "integer", "minimum": 0 },
        "transcription_cost_usd": { "type": "number", "minimum": 0 },
        "llm_cost_usd": { "type": "number", "minimum": 0 },
        "embedding_cost_usd": { "type": "number", "minimum": 0 },
        "cloud_total_cost_usd": { "type": "number", "minimum": 0 },
        "local_compute_cost_usd": { "type": "number", "minimum": 0 },
        "total_estimated_cost_usd": { "type": "number", "minimum": 0 },
        "cloud_carbon_gco2e": { "type": "number", "minimum": 0 },
        "local_incremental_carbon_gco2e": { "type": "number", "minimum": 0 },
        "total_consumer_carbon_gco2e": { "type": "number", "minimum": 0 },
        "avoided_cloud_carbon_gco2e": { "type": "number", "minimum": 0 },
        "net_avoided_total_carbon_gco2e": { "type": "number" },
        "direct_datacenter_water_liters": { "type": "number", "minimum": 0 },
        "avoided_direct_water_liters": { "type": "number", "minimum": 0 },
        "cloud_transfer_mb": { "type": "number", "minimum": 0 },
        "avoided_transfer_mb": { "type": "number", "minimum": 0 },
        "quality_score": { "type": "number", "minimum": 1, "maximum": 5 },
        "privacy_score": { "type": "number", "minimum": 1, "maximum": 5 },
        "offline_resilience_score": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
